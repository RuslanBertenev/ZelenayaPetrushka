    <bpmn:textAnnotation id="TextAnnotation_06o2ez0">
      <bpmn:text>есть не завершенные?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0hyd921">
      <bpmn:text>у пользователя включены push?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_10yfvwk">
      <bpmn:text>пользователь нажал на push?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0l30uou">
      <bpmn:text>запуск проверки раз в день</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_00wjm30">
      <bpmn:text>товары в наличии?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0tdo1g3">
      <bpmn:text>есть необходимые товары?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1ij64r4">
      <bpmn:text>оплата прошла успешно ?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0ycu9s4">
      <bpmn:text>Статус изменился?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_12ikgi0">
      <bpmn:text>заказ исполнен?</bpmn:text>
    </bpmn:textAnnotation>
